# PostgreSQL — mahalliy server. Masalan: createdb shoxsaroy

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=shoxsaroy
DB_SYNC=true

JWT_SECRET=change-me-in-production
JWT_EXPIRES_SEC=604800

# 64 ta hex belgi (32 bayt kalit): openssl rand -hex 32
ENCRYPTION_KEY=

SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# db:reset-superadmin-only: CONFIRM=YES va SUPERADMIN_EMAIL majburiy

# Bloklangan tashkilot foydalanuvchilariga ko‘rsatiladigan telefon (ixtiyoriy)
SUPPORT_PHONE=

# Vergul bilan ajratilgan originlar yoki bo'sh = barchasi
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Ixtiyoriy: umumiy MQTT ( /mqtt/sendmqtt — @Public() )
MQTT_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
