# =========================================================
# Shoxsaroy Backend — Environment Configuration Example
# Production'da har bir o'zgaruvchi to'g'ri qiymat bilan
# to'ldirilishi shart. Validation main bootstrap'da bajariladi.
# =========================================================

NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=shoxsaroy
# Production'da DB_SYNC=false bo'lishi SHART. Migrations'dan foydalaning.
DB_SYNC=false
# Managed Postgres (Supabase/Neon/RDS) uchun true qiling.
DB_SSL=false
DB_POOL_MAX=20
DB_CONN_TIMEOUT_MS=10000

# --- Auth ---
# Production: openssl rand -hex 48
JWT_SECRET=change-me-in-production
JWT_EXPIRES_SEC=604800

# 64 ta hex belgi (32 bayt kalit): openssl rand -hex 32
ENCRYPTION_KEY=

# --- Superadmin (faqat boshlang'ich seed uchun) ---
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Bloklangan tashkilot foydalanuvchilariga ko'rsatiladigan telefon
SUPPORT_PHONE=

# --- CORS ---
# Vergul bilan ajratilgan ro'yxat. /…/ formatdagi qiymatlar regex sifatida ishlatiladi.
# Showroom domeni bu yerda bo'lishi SHART.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=logs

# --- Rate limiting (umumiy default) ---
THROTTLE_TTL_SEC=60
THROTTLE_LIMIT=120

# --- MQTT (ixtiyoriy) ---
MQTT_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Showroom floor/apartment tayyorlash scripti ---
# npm run showroom:prepare-floor
SHOWROOM_BLOCK_ID=
SHOWROOM_SOURCE_FLOOR_ID=
SHOWROOM_TARGET_FLOOR_LEVELS=
SHOWROOM_SHIFT_STEP=100
SHOWROOM_COPY_PLAN=true
